entrypoint = "src/index.ts"
modules = ["nodejs-20", "python-3.11", "postgresql-16"]

[gitHubImport]
requiredFiles = [".replit", "replit.nix", "package.json", "package-lock.json"]

[nix]
channel = "stable-25_05"

[unitTest]
language = "nodejs"

[deployment]
run = ["bash", "-c", "npx vite build --config client-app/vite.config.ts && npx tsx server/admin-api/start.ts & npx tsx server/voice-gateway/start.ts & wait"]
deploymentTarget = "vm"
ignorePorts = false
build = ["bash", "-c", "npx tsc --noEmit"]

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 5174
externalPort = 3003

[[ports]]
localPort = 8000
externalPort = 8000

[agent]
expertMode = true
integrations = ["javascript_database:1.0.0", "twilio:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Platform Dev"

[[workflows.workflow]]
name = "Platform Dev"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/start-platform-dev.sh"
waitForPort = 5000

[userenv]

[userenv.shared]
DISABLE_PHI_LOGGING = "true"
TWILIO_OUTBOUND_NUMBER = "+16263821543"
SMTP_HOST = "smtp.office365.com"
SMTP_PORT = "587"

[userenv.development]
APP_ENV = "development"

[userenv.production]
APP_ENV = "production"
PORT = "5000"
